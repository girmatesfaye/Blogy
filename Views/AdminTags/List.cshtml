@model List<Blogy_MVC.Models.Domain.Tag>

<div class="bg-secondary bg-opacity-10 py-4">
    <div class="container">
        <h2>List of Tags</h2>
    </div>
</div>

<div class="container">
    @if (Model != null && Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Display Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var tag in Model)
            {
                    <tr>
                        <td > @tag.Id </td>
                        <td > @tag.Name </td>
                        <td > @tag.DisplayName </td>
                        <td>
                          <a asp-area=" " asp-controller="AdminTags" asp-action="Edit" asp-route-id = "@tag.Id">Edit</a>
                        </td>
                    </tr>
            
                }
            </tbody>
        </table>
    }
    else


{
<p>No tags found.</p>


}
</div>