@model Blogy_MVC.Models.ViewModels.EditTagRequest


<div class="bg-secondary bg-opacity-10 py-4">
    <div class="container">
        <h2>Edit Tags</h2>
    </div>
</div>

<form method="post" class="container mt-4">
    <div class="mb-3">
        <label class="form-label">Id</label>
        <input type="text" class="form-control" id="id" asp-for="Id" readonly>
    </div>
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" class="form-control" id="name" asp-for="Name">
    </div>
    <div class="mb-3">
        <label class="form-label">Display Name</label>
        <input type="text" class="form-control" id="displayName" asp-for="DisplayName">
    </div>

    <div class="flex gap-2">
        <button type="submit" class="btn btn-secondary">Update</button>
        <button type="submit" class="btn btn-danger" asp-controller="AdminTags" asp-action="Delete">
            Delete
        </button>
    </div>
</form>