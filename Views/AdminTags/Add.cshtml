@model Blogy_MVC.Models.ViewModels.AddTagRequest

<div class="bg-secondary bg-opacity-10 py-4">
    <div class="container">
        <h2>Add New Tags</h2>
    </div>
</div>

<form method="post" class="container mt-4">
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" class="form-control" id="name" asp-for="Name">
    </div>
    <div class="mb-3">
        <label class="form-label">Display Name</label>
        <input type="text" class="form-control" id="displayName" asp-for="DisplayName">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
</form>