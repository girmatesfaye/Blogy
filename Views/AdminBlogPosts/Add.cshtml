@model Blogy_MVC.Models.ViewModels.AddBlogPostRequest

<div class="bg-primary bg-gradient text-white py-4 mb-4">
    <div class="container">
        <h2 class="mb-0">Create Blog Post</h2>
        <p class="mb-0 opacity-75">Fill in the details below to publish a new blog post.</p>
    </div>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow border-0">
                <div class="card-body p-5">

                    <form method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Heading" class="form-label fw-semibold"></label>
                            <input asp-for="Heading" class="form-control form-control-lg"
                                   placeholder="Enter blog heading">
                            <span asp-validation-for="Heading" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PageTitle" class="form-label fw-semibold"></label>
                            <input asp-for="PageTitle" class="form-control" placeholder="SEO page title">
                        </div>

                        <div class="mb-4">
                            <label asp-for="ShortDescription" class="form-label fw-semibold"></label>
                            <textarea asp-for="ShortDescription" class="form-control" rows="3"
                                      placeholder="Write a short description"></textarea>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Content" class="form-label fw-semibold"></label>
                            <textarea asp-for="Content" class="form-control" rows="10"
                                      placeholder="Write your blog content here..."></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="FeatureImageUrl" class="form-label fw-semibold"></label>
                                <input asp-for="FeatureImageUrl" class="form-control"
                                       placeholder="https://example.com/image.jpg">
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="UrlHandle" class="form-label fw-semibold"></label>
                                <input asp-for="UrlHandle" class="form-control" placeholder="my-first-blog-post">
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="PublishedDate" class="form-label fw-semibold"></label>
                                <input asp-for="PublishedDate" type="date" class="form-control">
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Author" class="form-label fw-semibold"></label>
                                <input asp-for="Author" class="form-control" placeholder="Author name">
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="Visible" class="form-check-input">
                            <label asp-for="Visible" class="form-check-label fw-semibold"></label>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Tags</label>
                            <select class="form-select" asp-for="SelectedTags" asp-items="@Model.Tags"></select>
                        </div>
                        <hr class="my-4">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="List" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                Publish Blog Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

